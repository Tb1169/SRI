<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>SRI Test | 性压抑测试</title>

<style>
body {
font-family: Arial, sans-serif;
background:#f5f7fa;
margin:0;
padding:0;
}

.container {
max-width:800px;
margin:auto;
background:white;
padding:30px;
margin-top:40px;
border-radius:12px;
box-shadow:0 0 15px rgba(0,0,0,0.1);
}

h1 {
text-align:center;
}

.question {
margin-bottom:20px;
}

.scale label {
margin-right:10px;
}

button {
background:#4CAF50;
color:white;
padding:12px 20px;
border:none;
border-radius:6px;
cursor:pointer;
font-size:16px;
}

.result {
margin-top:30px;
padding:20px;
background:#eef3ff;
border-radius:8px;
display:none;
}

.disclaimer {
font-size:12px;
color:#666;
margin-top:20px;
}
</style>

</head>

<body>

<div class="container">

<h1>
Sexual Repression Inventory (SRI)<br>
性压抑量表（参考版）
</h1>

<p>
This questionnaire is not a clinical diagnostic tool.<br>
本测试不是临床诊断工具，仅供参考。
</p>

<form id="testForm">

<div id="questions"></div>

<button type="button" onclick="calculateScore()">
Submit 提交
</button>

</form>

<div id="result" class="result"></div>

<div class="disclaimer">
For educational use only.<br>
仅供教育参考用途。
</div>

</div>

<script>

const questions = [

"我在讨论性话题时感到明显不适 / I feel discomfort when discussing sexual topics.",
"我对自己的性想法感到羞耻 / I feel ashamed of my sexual thoughts.",
"我避免讨论性健康问题 / I avoid talking about sexual health.",
"我担心别人评价我的性表达 / I worry about being judged for sexual expression.",
"亲密行为让我感到焦虑 / Intimate situations make me anxious.",

"我避免表达亲密需求 / I avoid expressing intimacy needs.",
"我觉得表达性需求是不恰当的 / Expressing sexual needs feels inappropriate.",
"我倾向压抑亲密欲望 / I suppress intimate desires.",
"我难以讨论身体相关话题 / I find body-related discussions difficult.",
"亲密情境让我紧张 / I feel tense in intimate situations.",

"我习惯隐藏自己的亲密需求 / I hide my intimacy needs.",
"我对性话题容易产生压力 / Sexual topics create stress for me.",
"我觉得性需求应该被控制 / Sexual desires should be controlled.",
"我认为谈论性是不礼貌的 / Talking about sex feels impolite.",
"我避免身体亲密接触 / I avoid physical closeness.",

"我对身体感到不自在 / I feel uncomfortable with my body.",
"我不喜欢身体被关注 / I dislike body attention.",
"我在亲密互动中感到拘谨 / I feel stiff in intimacy.",
"我难以放松面对亲密关系 / I struggle to relax in intimacy.",
"我压抑性相关想法 / I repress sexual thoughts.",

"我从小被教育避免性话题 / I was taught to avoid sexual topics.",
"我认为性表达通常不合适 / Sexual expression feels improper.",
"我觉得性需求令人尴尬 / Sexual needs feel embarrassing.",
"我难以表达亲密情感 / I find it hard to express intimacy.",
"我避免可能的亲密场景 / I avoid potential intimate situations."

];

const container = document.getElementById("questions");

questions.forEach((q, i) => {

let div = document.createElement("div");
div.className="question";

div.innerHTML = `<p>${i+1}. ${q}</p>
<div class="scale">

<label><input type="radio" name="q${i}" value="1">1</label>
<label><input type="radio" name="q${i}" value="2">2</label>
<label><input type="radio" name="q${i}" value="3">3</label>
<label><input type="radio" name="q${i}" value="4">4</label>
<label><input type="radio" name="q${i}" value="5">5</label>

</div>`;

container.appendChild(div);

});

function calculateScore(){

let total=0;

for(let i=0;i<questions.length;i++){

let radios=document.getElementsByName("q"+i);

let answered=false;

for(let r of radios){

if(r.checked){

total+=parseInt(r.value);
answered=true;

}

}

if(!answered){

alert("Please answer all questions. 请完成所有问题");
return;

}

}

let level="";

if(total<=45){

level="Low Repression 低压抑";

}else if(total<=65){

level="Mild Repression 轻度压抑";

}else if(total<=85){

level="Moderate Repression 中度压抑";

}else if(total<=105){

level="High Repression 较高压抑";

}else{

level="Very High Repression 高度压抑";

}

document.getElementById("result").style.display="block";

document.getElementById("result").innerHTML=

`Total Score 总分: <b>${total}</b><br>
Level 等级: <b>${level}</b>`;

}

</script>

</body>

</html>
